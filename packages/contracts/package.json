{
  "name": "@xphere-swap/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "build": "hardhat compile",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "node:localhost": "node scripts/start-node.mjs 8545 31337",
    "node:local-ethereum": "node scripts/start-node.mjs 8546 31338",
    "deploy:swap:localhost": "hardhat run scripts/deploy-local-swap.ts --network localhost",
    "deploy:bridge:local-ethereum": "hardhat run scripts/deploy-local-bridge.ts --network localEthereum",
    "deploy:bridge:localhost": "hardhat run scripts/deploy-local-bridge.ts --network localhost",
    "relay:local-bridge": "node scripts/relay-local-bridge.mjs",
    "generate:operators": "ts-node scripts/generate-operator-wallets.ts",
    "deploy:admin:localhost": "hardhat run scripts/deploy-admin-multisig.ts --network localhost",
    "deploy:admin:ethereum-mainnet": "hardhat run scripts/deploy-admin-multisig.ts --network ethereumMainnet",
    "deploy:admin:xphere-testnet": "hardhat run scripts/deploy-admin-multisig.ts --network xphereTestnet",
    "deploy:admin:xphere-mainnet": "hardhat run scripts/deploy-admin-multisig.ts --network xphereMainnet",
    "deploy:swap:xphere-testnet": "hardhat run scripts/deploy-xphere-swap.ts --network xphereTestnet",
    "deploy:swap:xphere-mainnet": "hardhat run scripts/deploy-xphere-swap.ts --network xphereMainnet",
    "seed:liquidity:localhost": "hardhat run scripts/seed-xphere-liquidity.ts --network localhost",
    "seed:liquidity:xphere-testnet": "hardhat run scripts/seed-xphere-liquidity.ts --network xphereTestnet",
    "seed:liquidity:xphere-mainnet": "hardhat run scripts/seed-xphere-liquidity.ts --network xphereMainnet",
    "smoke:rpc": "hardhat run scripts/smoke-rpc.ts",
    "smoke:local-swap": "hardhat run scripts/smoke-local-swap.ts --network localhost",
    "smoke:local-bridge": "hardhat run scripts/smoke-local-bridge.ts --network localhost",
    "preflight:localhost": "hardhat run scripts/preflight.ts --network localhost",
    "preflight:local-ethereum": "hardhat run scripts/preflight.ts --network localEthereum",
    "preflight:xphere-testnet": "hardhat run scripts/preflight.ts --network xphereTestnet",
    "preflight:xphere-mainnet": "hardhat run scripts/preflight.ts --network xphereMainnet",
    "probe:xphere-mainnet": "hardhat run scripts/probe-xphere-mainnet.ts --network xphereMainnet",
    "probe:mainnet-funding": "hardhat run scripts/probe-mainnet-funding.ts",
    "verify:localhost": "hardhat run scripts/verify-deployment.ts --network localhost",
    "verify:local-ethereum": "hardhat run scripts/verify-deployment.ts --network localEthereum",
    "verify:xphere-testnet": "hardhat run scripts/verify-deployment.ts --network xphereTestnet",
    "verify:xphere-mainnet": "hardhat run scripts/verify-deployment.ts --network xphereMainnet"
  },
  "dependencies": {
    "@uniswap/lib": "^4.0.1-alpha",
    "@uniswap/v2-core": "^1.0.1",
    "@uniswap/v2-periphery": "^1.1.0-beta.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.1",
    "dotenv": "^16.4.7",
    "ethers": "^6.17.0",
    "hardhat": "^2.22.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
